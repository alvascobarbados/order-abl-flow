# Copy to .env and fill in values from Lovable Cloud → Connectors.
# Do NOT commit .env.

# Client-visible (Vite-injected, safe to ship in bundle)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Server-only (SSR / server functions)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
